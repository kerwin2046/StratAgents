# DeepSeek API (required for LLM)
# Get your key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key

# Optional: model name (default: deepseek-reasoner, better for analysis)
# Options: deepseek-reasoner, deepseek-chat, deepseek-coder
# DEEPSEEK_MODEL_NAME=deepseek-reasoner

# Bright Data API (required for web scraping in research agent)
BRIGHTDATA_API_KEY=your_brightdata_api_key
