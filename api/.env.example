# DeepSeek API (required for LLM)
# Get your key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key

# Optional: model name (default: deepseek-chat; use reasoner only without tool-calling agents)
# deepseek-reasoner can cause 400 with tool calls (reasoning_content). Prefer deepseek-chat for this workflow.
# DEEPSEEK_MODEL_NAME=deepseek-chat

# Bright Data API (required for web scraping in research agent)
BRIGHTDATA_API_KEY=your_brightdata_api_key

# CORS: comma-separated origins (default: localhost for dev)
# Example: http://localhost:5173,https://app.example.com
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: custom path for session persistence (default: .data/sessions.json)
# SESSIONS_FILE=.data/sessions.json
